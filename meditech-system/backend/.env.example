# Variables de entorno para MediTech System
# Copia este archivo a .env y ajusta los valores

# ==================== APLICACIÓN ====================
APP_NAME=MediTech System
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# ==================== BASE DE DATOS ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=meditech_db
DB_USER=meditech_user
DB_PASSWORD=cambia_esta_contrasena_en_produccion
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ==================== SEGURIDAD JWT ====================
# Genera una clave segura con: openssl rand -hex 32
SECRET_KEY=tu-clave-secreta-muy-larga-y-segura-cambiala-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== REDIS ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== CELERY ====================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ==================== ORTHANC (PACS) ====================
ORTHANC_URL=http://localhost:8042
ORTHANC_USERNAME=orthanc
ORTHANC_PASSWORD=orthanc

# ==================== OPENELIS (LIS) ====================
OPENELIS_URL=http://localhost:8080
OPENELIS_USERNAME=admin
OPENELIS_PASSWORD=admin!@#

# ==================== ARCHIVOS ====================
UPLOAD_DIR=/var/meditech/uploads
RESULTS_DIR=/var/meditech/results
MAX_UPLOAD_SIZE=52428800

# ==================== CORS ====================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ==================== RATE LIMITING ====================
RATE_LIMIT_PER_MINUTE=100

# ==================== PAGOS (OPCIONAL) ====================
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# ==================== EMAIL (OPCIONAL) ====================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@meditech.com
